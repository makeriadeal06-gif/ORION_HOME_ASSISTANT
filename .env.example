# ORION Core Configuration
PORT=3000

# TriggerCMD Real Integration (optional; fallback remains active)
TRIGGERCMD_DEVICES_URL=https://www.triggercmd.com/api/command/list
TRIGGERCMD_EXECUTE_URL=https://www.triggercmd.com/api/run/trigger

# MQTT Infrastructure (WSS required for browser client)
VITE_MQTT_URL=wss://broker.hivemq.com:8884/mqtt

# ElevenLabs Voice (TTS provider for personalized voice)
# Set ELEVENLABS_API_KEY in your local .env (do NOT commit secrets)
ELEVENLABS_VOICE_ID=kxGXJuL3rT7BVU1BGnK4
VITE_VOICE_PROVIDER_DIAGNOSTIC=false

# Realtime & Bridge Params
SOCKET_SECRET=orion_runtime_secure_alpha_x91
RECOVERY_THRESHOLD_MS=15000

# Notes:
# - Do NOT commit real API keys, service account JSON or private keys.
# - Use .env locally and set environment variables in your hosting provider (Vercel/Netlify).
# - If you accidentally commit a secret, rotate it immediately and remove it from Git history.
